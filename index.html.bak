<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
function showPanel(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  btn.classList.add('active');
}

function drawDonut(id, data, colors) {
  const canvas = document.getElementById(id);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const total = data.reduce((a,b)=>a+b,0);
  let start = -Math.PI/2;
  const cx=canvas.width/2, cy=canvas.height/2, r=62, ir=42;
  data.forEach((val,i)=>{
    const angle=(val/total)*2*Math.PI;
    ctx.beginPath(); ctx.moveTo(cx,cy);
    ctx.arc(cx,cy,r,start,start+angle); ctx.closePath();
    ctx.fillStyle=colors[i]; ctx.fill(); start+=angle;
  });
  ctx.beginPath(); ctx.arc(cx,cy,ir,0,Math.PI*2);
  ctx.fillStyle='#111318'; ctx.fill();
}
drawDonut('kospiChart',[671,199,80],['#ff6b3d','#4a9eff','#2a2e38']);
drawDonut('kosdaqChart',[1284,327,212],['#4ecb8a','#4a9eff','#2a2e38']);

// ── NEWS LOADER ──
let currentStock = null;

async function loadNews(rowEl, name, market, change, price, vol) {
  document.querySelectorAll('.stock-row.clickable').forEach(r => r.classList.remove('selected'));
  rowEl.classList.add('selected');
  currentStock = name;

  const isUp = change.startsWith('+');
  document.getElementById('news-stock-bar').style.display = 'flex';
  document.getElementById('news-stock-name').textContent = name;
  document.getElementById('news-stock-meta').innerHTML =
    `${market} &nbsp;·&nbsp; ${price} &nbsp;·&nbsp; <span style="color:${isUp?'var(--up)':'var(--dn)'}">${change}</span> &nbsp;·&nbsp; ${vol}`;

  document.getElementById('news-panel-el').classList.add('active-panel');

  const body = document.getElementById('news-body');
  body.innerHTML = `
    <div class="news-loading">
      <div class="spinner"></div>
      <div class="loading-label">${name} 검색 중<span class="loading-dots"></span></div>
    </div>`;

  try {
    const prompt = `당신은 한국 주식 시장 전문 애널리스트입니다.
종목: ${name} (${market})
전일(2026-04-14~15) 주가변동: ${change}, 종가 ${price}, 거래대금 ${vol}

이 종목의 주가 변동 원인이 된 뉴스, 공시, 애널리스트 코멘트를 3~4개 항목으로 정리하세요.
반드시 아래 JSON 배열만 출력하세요. 다른 텍스트 없이:
[{"type":"뉴스"|"공시"|"애널리스트","headline":"제목(25자이내)","summary":"2~3문장 한국어 요약","date":"2026.04.14 또는 2026.04.15"}]`;

    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        tools: [{ type: 'web_search_20250305', name: 'web_search' }],
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await res.json();
    if (!res.ok) throw new Error(data.error?.message || `HTTP ${res.status}`);
    if (currentStock !== name) return;

    const allText = data.content.filter(b=>b.type==='text').map(b=>b.text).join('');
    const match = allText.match(/\[[\s\S]*?\]/);
    if (!match) throw new Error('응답 형식 오류');

    const items = JSON.parse(match[0]);
    const tagClass = { '뉴스':'tag-news', '공시':'tag-disc', '애널리스트':'tag-analyst' };

    body.innerHTML = items.map(item => `
      <div class="news-item">
        <span class="news-tag ${tagClass[item.type]||'tag-news'}">${item.type}</span>
        <div class="news-headline">${item.headline}</div>
        <div class="news-summary">${item.summary}</div>
        <div class="news-date">${item.date}</div>
      </div>`).join('');

  } catch(e) {
    if (currentStock !== name) return;
    body.innerHTML = `<div class="news-error"><strong>뉴스 조회 실패</strong>${e.message}</div>`;
  }
}
</script>
</body>
</html>
